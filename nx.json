{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": [
        "default"
      ],
      "outputs": [
        "{workspaceRoot}/dist/{projectName}"
      ]
    }
  },
  "analytics": true
}